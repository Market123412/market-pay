# ============================================
# MarketPay - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha com suas chaves reais:
#   cp .env.example .env.local
# ============================================

# --- Amazon Product Advertising API (PA-API 5.0) ---
# Cadastre-se em: https://affiliate-program.amazon.com.br
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_REGION=us-east-1

# --- Mercado Livre API ---
# Cadastre-se em: https://developers.mercadolivre.com.br
MERCADOLIVRE_APP_ID=
MERCADOLIVRE_CLIENT_SECRET=
MERCADOLIVRE_REDIRECT_URI=http://localhost:3000/api/auth/mercadolivre/callback
MERCADOLIVRE_ACCESS_TOKEN=

# --- Shopee Open Platform ---
# Cadastre-se em: https://open.shopee.com.br
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_AFFILIATE_ID=

# --- Google AdSense ---
# Cadastre-se em: https://adsense.google.com
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# --- Site URL (para deploy) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
